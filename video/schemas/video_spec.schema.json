{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VideoSpec",
  "description": "Contract between Python pipeline and Remotion renderer for JSup thread-to-video pipeline",
  "type": "object",
  "required": ["id", "title", "created_at", "settings", "intro", "outro", "slides", "youtube"],
  "properties": {
    "id": { "type": "string", "description": "Unique run identifier, matches published slug" },
    "title": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "settings": {
      "type": "object",
      "required": ["width", "height", "fps", "theme", "background_music", "background_music_volume", "transition_duration_frames"],
      "properties": {
        "width": { "type": "integer", "default": 1080 },
        "height": { "type": "integer", "default": 1920 },
        "fps": { "type": "integer", "default": 30 },
        "theme": { "type": "string", "default": "dark" },
        "background_music": { "type": "string" },
        "background_music_volume": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.08 },
        "transition_duration_frames": { "type": "integer", "default": 15 }
      }
    },
    "intro": {
      "type": "object",
      "required": ["duration_seconds", "handle", "logo_text"],
      "properties": {
        "duration_seconds": { "type": "number" },
        "handle": { "type": "string" },
        "logo_text": { "type": "string" }
      }
    },
    "outro": {
      "type": "object",
      "required": ["duration_seconds", "cta_text", "handle"],
      "properties": {
        "duration_seconds": { "type": "number" },
        "cta_text": { "type": "string" },
        "handle": { "type": "string" }
      }
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["slide_number", "total_slides", "text", "audio_file", "captions_file"],
        "properties": {
          "slide_number": { "type": "integer", "minimum": 1 },
          "total_slides": { "type": "integer", "minimum": 1 },
          "text": { "type": "string" },
          "audio_file": { "type": "string" },
          "captions_file": { "type": "string" },
          "duration_ms": { "type": ["number", "null"] },
          "theme_override": { "type": ["string", "null"] }
        }
      }
    },
    "youtube": {
      "type": "object",
      "required": ["title", "description", "tags", "category_id", "default_language", "contains_synthetic_media"],
      "properties": {
        "title": { "type": "string", "maxLength": 100 },
        "description": { "type": "string", "maxLength": 5000 },
        "tags": { "type": "array", "items": { "type": "string" } },
        "category_id": { "type": "string", "default": "28" },
        "default_language": { "type": "string", "default": "ko" },
        "playlist_id": { "type": ["string", "null"] },
        "contains_synthetic_media": { "type": "boolean", "default": true }
      }
    }
  }
}
